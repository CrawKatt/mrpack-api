# ============================================================================
# Mrpack API - Configuration
# ============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================================================

# ----------------------------------------------------------------------------
# Server Configuration
# ----------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# ----------------------------------------------------------------------------
# Admin Authentication
# ----------------------------------------------------------------------------
# REQUIRED: Set your admin username (minimum 3 characters)
ADMIN_USERNAME=admin

# REQUIRED: Generate a password hash using:
#   cargo run --bin hash_password "YourPassword"
# Then paste the hash here BETWEEN SINGLE QUOTES:
ADMIN_PASSWORD_HASH=''

# Example hash format (DO NOT USE THIS - generate your own):
# ADMIN_PASSWORD_HASH='$argon2id$v=19$m=19456,t=2,p=1$...'
#
# IMPORTANT: Use single quotes to prevent shell variable expansion!

# ----------------------------------------------------------------------------
# Storage Configuration
# ----------------------------------------------------------------------------
# Directory where modpack files will be stored
STORAGE_DIR=storage

# Maximum file size in megabytes (1-10240)
MAX_FILE_SIZE_MB=500

# ----------------------------------------------------------------------------
# Security Configuration
# ----------------------------------------------------------------------------
# Set to true in production to enforce HTTPS checks
REQUIRE_HTTPS=false

# CORS: Comma-separated list of allowed origins
# Leave empty to allow all origins (NOT RECOMMENDED for production)
# Example: ALLOWED_ORIGINS=https://example.com,https://app.example.com
ALLOWED_ORIGINS=

# ----------------------------------------------------------------------------
# Environment
# ----------------------------------------------------------------------------
# Set to "production" in production environments
# This enables additional security warnings and checks
RUST_ENV=development

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
# Log level: error, warn, info, debug, trace
# For production, use: info or warn
# For development, use: debug or trace
RUST_LOG=info

# Or configure per-module:
# RUST_LOG=mrpack_api=debug,tower_http=info,axum=info

# ============================================================================
# PRODUCTION CHECKLIST
# ============================================================================
# Before deploying to production, ensure:
# 
# [ ] ADMIN_USERNAME is set to a non-default value
# [ ] ADMIN_PASSWORD_HASH is generated with a strong password (12+ chars)
# [ ] REQUIRE_HTTPS is set to true
# [ ] ALLOWED_ORIGINS is configured with specific domains
# [ ] RUST_ENV is set to "production"
# [ ] RUST_LOG is set to "info" or "warn"
# [ ] MAX_FILE_SIZE_MB is appropriate for your use case
# [ ] .env file is NOT in version control
# [ ] File permissions on .env are restricted (chmod 600)
# [ ] Server is behind a reverse proxy with SSL/TLS
# [ ] Firewall is properly configured
# [ ] Regular backups of storage/ directory are scheduled
#
# ============================================================================

# ============================================================================
# QUICK START
# ============================================================================
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Generate password hash:
#    cargo run --bin hash-password "YourSecurePassword123!"
#
# 3. Edit .env and set ADMIN_USERNAME and ADMIN_PASSWORD_HASH
#
# 4. Start the server:
#    cargo run --release
#
# ============================================================================